# ─────────────────────────────────────────────────────────────
# Snapsold — environment variables
# Copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored. NEVER commit real keys.
# ─────────────────────────────────────────────────────────────

# ── Supabase (auth + saved analyses)
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy anon key name — still works if you haven't migrated to publishable keys:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — NEVER expose to the client or commit real values:
# SUPABASE_SERVICE_ROLE_KEY=

# ── SerpAPI (live eBay sold listings — required for production pricing)
# https://serpapi.com/manage-api-key
SERPAPI_KEY=
# Optional — force mock sold-listing data even when a key is set
# EBAY_USE_MOCK=true
# EBAY_DOMAIN=ebay.com
# LISTINGS_CACHE_TTL_SECONDS=86400

# ── Google AI Studio (photo identification via Gemini)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_VISION_MODEL=gemini-2.5-flash

# ── KicksDB (StockX sneaker market data — optional)
# https://kicks.dev/api-keys — free tier: 1,000 Standard API requests/month
KICKS_API_KEY=

# ── eBay Browse API (Phase 2 — sold/active listings)
# https://developer.ebay.com — create an app, use Production or Sandbox
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
EBAY_ENV=production            # or `sandbox` while developing

# ── OpenRouter (Phase 4 — AI listing title + summaries)
# https://openrouter.ai/keys — start with a free model
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-flash-1.5   # cheap default; swap as needed

# ── OCR.space (Phase 2 — extract text from product photos)
# https://ocr.space/ocrapi — free tier is 25k/month
OCR_SPACE_API_KEY=

# Optional — used for auth email redirect URLs in production
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
# Used to sign rate-limit cookies / future webhook secrets
APP_SECRET=
